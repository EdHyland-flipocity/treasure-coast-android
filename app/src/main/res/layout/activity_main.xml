<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060D1A">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/splashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#060D1A"
        android:padding="32dp">

        <TextView
            android:text="TC"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:gravity="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2ABFB0"
            android:background="@drawable/circle_border"
            android:layout_marginBottom="24dp" />

        <TextView
            android:text="Treasure Coast Intelligence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#5ED8CC"
            android:layout_marginBottom="8dp" />

        <TextView
            android:text="Flipocity Analytics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#4A6080"
            android:letterSpacing="0.15"
            android:layout_marginBottom="48dp" />

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="#2ABFB0"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/splashText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Initializing..."
            android:textSize="13sp"
            android:textColor="#6B7A8D"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

</FrameLayout>
